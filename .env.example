# WORDPRESS_POSTS_API_URL=https://tvenserio.com/wp-json/wp/v2/posts
# Usa WORDPRESS_JWT_TOKEN o usuario + Application Password de WordPress.
WORDPRESS_JWT_TOKEN=
WORDPRESS_USERNAME=
WORDPRESS_APPLICATION_PASSWORD=
# El scraping automatico corre al iniciar la app y luego cada minuto.
STARTUP_SCRAPE_ENABLED=true
STARTUP_SCRAPE_DELAY_MS=15000
-DOMINIO/webhook/...